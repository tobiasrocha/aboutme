<!DOCTYPE html>
<%
var pageLang = typeof lang !== 'undefined' ? lang : 'pt';
%>
<html lang="<%= pageLang === 'en' ? 'en' : 'pt' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageLang === 'en' ? (profile.name_en || profile.name) : profile.name %> &mdash; About</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="theme-<%= profile.theme || 'dark' %>">
  <canvas id="nodes-canvas"></canvas>

  <div class="page">
    <nav class="topbar">
      <% if (profile.links) { %>
        <% profile.links.forEach(function(link) { %>
          <a href="<%= link.url %>" class="btn" target="_blank" rel="noopener"><%= link.label %></a>
        <% }); %>
      <% } %>
      <button class="btn btn-contact" data-info="whatsapp" type="button">
        <%= pageLang === 'en' ? 'Contact' : 'Contato' %>
      </button>
      <button class="btn btn-contact" data-info="email" type="button">
        <%= pageLang === 'en' ? 'E-mail' : 'E-mail' %>
      </button>
      <a href="/" class="btn btn-lang<%= pageLang === 'pt' ? ' active' : '' %>" title="Portugu&ecirc;s">
        <img src="/img/flag-br.svg" alt="PT" class="flag-icon">
      </a>
      <a href="/en" class="btn btn-lang<%= pageLang === 'en' ? ' active' : '' %>" title="English">
        <img src="/img/flag-us.svg" alt="EN" class="flag-icon">
      </a>
    </nav>

    <div class="avatar" id="avatar-audio" style="cursor:pointer" title="<%= pageLang === 'en' ? 'Click to listen' : 'Clique para ouvir' %>">
      <% if (profile.avatar) { %>
        <img src="<%= profile.avatar %>" alt="<%= pageLang === 'en' ? 'Profile photo' : 'Foto de perfil' %>">
      <% } else { %>
        <div class="avatar-placeholder"><%= (pageLang === 'en' ? (profile.name_en || profile.name) : profile.name).charAt(0) %></div>
      <% } %>
    </div>

    <h1><%= pageLang === 'en' ? (profile.name_en || profile.name) : profile.name %></h1>
    <p class="tagline"><%= pageLang === 'en' ? (profile.tagline_en || profile.tagline) : profile.tagline %></p>

    <div class="bio">
      <% var bioText = pageLang === 'en' ? (profile.bio_en || profile.bio) : profile.bio; %>
      <% bioText.split('\n').forEach(function(para) { %>
        <% if (para.trim()) { %>
          <p><%= para.trim() %></p>
        <% } %>
      <% }); %>
    </div>

    <% if (profile.location) { %>
    <p class="location"><%= profile.location %></p>
    <% } %>
  </div>

  <div class="modal-overlay" id="info-modal" aria-hidden="true">
    <div class="modal-box modal-info">
      <button class="modal-close" id="modal-close" type="button" aria-label="<%= pageLang === 'en' ? 'Close' : 'Fechar' %>">&times;</button>
      <div id="info-whatsapp" class="info-content" style="display:none">
        <h2 class="modal-title">WhatsApp</h2>
        <p class="info-value" id="whatsapp-value"><%= whatsapp %></p>
        <a id="whatsapp-link" href="https://wa.me/<%= whatsapp %>" target="_blank" rel="noopener" class="btn btn-send">
          <%= pageLang === 'en' ? 'Open WhatsApp' : 'Abrir WhatsApp' %>
        </a>
      </div>
      <div id="info-email" class="info-content" style="display:none">
        <h2 class="modal-title">E-mail</h2>
        <p class="info-value" id="email-value"><%= email %></p>
        <a id="email-link" href="mailto:<%= email %>" class="btn btn-send">
          <%= pageLang === 'en' ? 'Send E-mail' : 'Enviar E-mail' %>
        </a>
      </div>
    </div>
  </div>

  <script>
    var audioTobias = new Audio(<%- pageLang === 'en' ? "'/voz-tobias-eng.m4a'" : "'/voz-tobias.m4a'" %>);
    document.getElementById('avatar-audio').addEventListener('click', function() {
      audioTobias.currentTime = 0;
      audioTobias.play().catch(function(e) {
        console.log('Audio nao pode ser reproduzido:', e);
      });
    });

    (function() {
      var modal = document.getElementById('info-modal');
      var btnClose = document.getElementById('modal-close');
      var infoWhatsapp = document.getElementById('info-whatsapp');
      var infoEmail = document.getElementById('info-email');

      function openModal(type) {
        infoWhatsapp.style.display = type === 'whatsapp' ? 'block' : 'none';
        infoEmail.style.display = type === 'email' ? 'block' : 'none';
        modal.setAttribute('aria-hidden', 'false');
      }

      document.querySelectorAll('[data-info]').forEach(function(btn) {
        btn.addEventListener('click', function() { openModal(btn.getAttribute('data-info')); });
      });

      btnClose.addEventListener('click', function() { modal.setAttribute('aria-hidden', 'true'); });
      modal.addEventListener('click', function(e) { if (e.target === modal) modal.setAttribute('aria-hidden', 'true'); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') modal.setAttribute('aria-hidden', 'true');
      });

      var w = document.getElementById('whatsapp-value');
      if (w && w.textContent.trim()) {
        var n = w.textContent.trim();
        var f = n.replace(/^(\d{2})(\d{2})(\d{5})(\d{4})$/, '+$1 ($2) $3-$4');
        w.textContent = f;
        document.getElementById('whatsapp-link').href = 'https://wa.me/' + n;
      }
    })();
  </script>
  <script src="/js/particles.js"></script>
</body>
</html>
